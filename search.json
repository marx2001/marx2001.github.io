---
layout: null
permalink: /search.json
---
[
{% assign posts = site.posts %}
{% for post in posts %}

  {%- capture raw_content -%}{{ post.content }}{%- endcapture -%}
  {%- assign pre_parts = raw_content | split: "<pre" -%}

  {%- capture content_no_code -%}
    {{ pre_parts[0] }}
    {%- for part in pre_parts offset:1 -%}
      {%- assign tail_parts = part | split: "</pre>" -%}
      {%- for tail in tail_parts offset:1 -%}
        {{ tail }}
      {%- endfor -%}
    {%- endfor -%}
  {%- endcapture -%}

  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "content": {{ content_no_code | strip_html | strip_newlines | replace: "\n", " " | replace: "\r", " " | replace: "  ", " " | truncate: 1200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]